<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>Project NP: Grandparent Sentinel Adelic Engine</title>
    <style>
        :root { --neon: #00ff41; --bg: #050505; --blue: #3498db; --warning: #ff3e3e; }
        body { background: var(--bg); color: var(--neon); font-family: 'Courier New', monospace; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .oracle-shell { border: 2px solid var(--neon); background: #000; width: 95%; max-width: 900px; padding: 30px; box-shadow: 0 0 50px rgba(0,255,65,0.15); position: relative; }
        header { text-align: center; margin-bottom: 25px; border-bottom: 1px solid #333; padding-bottom: 10px; }
        .subtitle { letter-spacing: 5px; color: var(--blue); font-size: 0.8em; }
        
        label { display: block; margin-top: 15px; font-size: 0.9em; opacity: 0.8; }
        input { background: #111; color: var(--neon); border: 1px solid var(--neon); padding: 15px; width: 100%; box-sizing: border-box; font-size: 1.1em; text-align: center; margin: 10px 0; outline: none; transition: 0.3s; }
        input:focus { box-shadow: 0 0 15px var(--blue); border-color: var(--blue); }
        
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        button { background: var(--neon); color: #000; border: none; padding: 18px; cursor: pointer; font-weight: bold; letter-spacing: 2px; transition: 0.2s; }
        button:hover { background: #fff; box-shadow: 0 0 30px var(--neon); }
        button.secondary { background: #222; color: var(--blue); border: 1px solid var(--blue); }
        
        .manifold { display: grid; grid-template-columns: repeat(auto-fill, minmax(12px, 1fr)); gap: 2px; margin: 25px 0; border: 1px solid #222; padding: 10px; height: 120px; overflow-y: auto; background: #080808; }
        .bit { height: 12px; border: 1px solid #111; }
        .bit.active { background: var(--blue); box-shadow: 0 0 5px var(--blue); }
        .bit.sieve-fail { background: var(--warning); }

        .readout { border-top: 1px solid #333; padding-top: 20px; display: none; }
        .status-bar { display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 15px; font-size: 0.9em; }
        .option-card { border: 1px solid #222; padding: 15px; margin-bottom: 10px; background: rgba(0,255,65,0.02); }
        .val { color: var(--blue); word-break: break-all; font-weight: bold; }
        .tag { font-size: 0.7em; padding: 2px 6px; border-radius: 3px; margin-left: 10px; background: #111; }
        .tag.prime { border: 1px solid var(--neon); color: var(--neon); }
        .tag.sieve { border: 1px solid var(--blue); color: var(--blue); }
    </style>
</head>
<body>

<div class="oracle-shell">
    <header>
        <h1>PROJECT NP</h1>
        <div class="subtitle">ADELIC TRANSITION & SINGULARITY RESOLVER</div>
    </header>

    <label>INPUT ARBITRARY RESULT (R) - [Adelic Bitstream]</label>
    <input type="text" id="targetRes" placeholder="輸入大整數..." value="7257415615307994035399338719773190078211440323236761244511547401693626260131656991106275446128502321289178000385733128527959028895124771329960110320571859859376331885082810757401179926253579342429617207433205500000000000000000000000000000000000000000">

    <div class="controls">
        <button onclick="resolveNP(false)">執行 NP 分裂</button>
        <button class="secondary" onclick="resolveNP(true)">啟動三重模數篩選</button>
    </div>

    <div id="manifold" class="manifold"></div>

    <div id="output" class="readout">
        <div class="status-bar">
            <span id="statusText">系統就緒</span>
            <span id="sieveStatus"></span>
        </div>
        <div id="resultsList"></div>
    </div>
</div>

<script>
    // 2-adic 快速冪與梅森檢驗
    function bigIntPowerMod(base, exp, mod) {
        let res = 1n;
        base = base % mod;
        while (exp > 0n) {
            if (exp % 2n === 1n) res = (res * base) % mod;
            base = (base * base) % mod;
            exp = exp / 2n;
        }
        return res;
    }

    function isMersennePrime(p) {
        if (p < 2n) return false;
        // 簡單費馬檢查 (2^(p-1) % p == 1)
        return bigIntPowerMod(2n, p - 1n, p) === 1n;
    }

    // 三重模數篩選 (Triple-Moduli Sieve: 5, 7, 53)
    function tripleModSieve(n) {
        // 根據 Project NP 手冊，有效的 Hamiltonian 軌跡需滿足特定對稱性
        const m5 = n % 5n === 0n;
        const m7 = n % 7n === 0n;
        const m53 = n % 53n === 0n;
        return { pass: m5 && m7 && m53, detail: `(M5:${m5?'O':'X'} M7:${m7?'O':'X'} M53:${m53?'O':'X'})` };
    }

    async function resolveNP(useSieve) {
        const raw = document.getElementById('targetRes').value;
        if (!raw) return;
        
        const R = BigInt(raw.replace(/\s/g, ''));
        const manifold = document.getElementById('manifold');
        const resultsList = document.getElementById('resultsList');
        const output = document.getElementById('output');
        const statusText = document.getElementById('statusText');
        
        manifold.innerHTML = "";
        resultsList.innerHTML = "";
        output.style.display = "block";

        let options = [];
        let tempR = R;
        let powerOfTwo = 1n;
        let bitDepth = 0;

        // Marilyn Fold: 位元剝離與 2-adic 賦值演繹
        while (tempR > 0n && tempR % 2n === 0n) {
            powerOfTwo *= 2n;
            tempR /= 2n;
            bitDepth++;

            let p_val = powerOfTwo - 1n; // 哨兵值 P
            let n_val = R / (p_val + 1n); // 地面態 N

            let sieve = useSieve ? tripleModSieve(n_val) : { pass: true, detail: "" };
            
            if (sieve.pass || !useSieve) {
                options.push({
                    n: n_val,
                    p: p_val,
                    depth: bitDepth,
                    isMersenne: isMersennePrime(p_val),
                    sieve: sieve
                });
            }
        }

        // 渲染 Adelic 流形位元圖
        const bits = R.toString(2).slice(-1000); // 顯示後 1000 位
        for (let b of bits) {
            const div = document.createElement('div');
            div.className = `bit ${b === '1' ? 'active' : ''}`;
            manifold.appendChild(div);
        }

        statusText.innerText = `奇點解析完成：發現 ${options.length} 組 NP 組合 [2-adic Depth: ${bitDepth}]`;
        
        options.forEach(opt => {
            const card = document.createElement('div');
            card.className = 'option-card';
            card.innerHTML = `
                <div>組合位階: <span class="val">2^${opt.depth}</span> 
                    ${opt.isMersenne ? '<span class="tag prime">Mersenne Sentinel</span>' : ''}
                    ${useSieve ? `<span class="tag sieve">Sieve ${opt.sieve.detail}</span>` : ''}
                </div>
                <div style="margin-top:8px;">INFERRED N: <span class="val">${opt.n}</span></div>
                <div style="margin-top:4px;">SENTINEL P: <span class="val">${opt.p}</span></div>
            `;
            resultsList.appendChild(card);
        });
    }
</script>
</body>
</html>

